{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist-test",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": false,
    "sourceMap": false,
    "lib": ["ES2020"],
    "types": ["node"],
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/game/**/*",
    "src/i18n/Locale.ts",
    "src/persistence/SaveValidation.ts",
    "src/tests/**/*"
  ],
  "exclude": ["node_modules", "dist", "dist-test"]
}
